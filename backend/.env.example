
# 后端环境变量示例文件。
#
# 用途：说明应用启动所需的配置项，开发者可复制为本地 `.env` 后填写实际值。
# 安全要求：本文件仅保留示例值；真实 API 密钥、生产数据库地址等敏感信息必须通过
# 未纳入版本控制的 `.env` 文件或部署平台的环境变量注入。

# 数据库连接地址。相对 SQLite 路径以后端进程的当前工作目录为基准，便于本地快速启动。
DATABASE_URL=sqlite+aiosqlite:///resource/database.db

# 应用基础配置。生产环境通常应关闭 DEBUG，避免向客户端暴露调试细节。
DEBUG=False
APP_NAME=AI ChatKit

# OpenAI 服务配置。BASE_URL 可指向兼容 OpenAI API 协议的服务端点。
OPENAI_BASE_URL=https://api.openai.com/v1
# 示例占位符：真实密钥仅应配置在私有 `.env` 或部署环境中。
OPENAI_API_KEY=your_openai_api_key

# DeepSeek 服务配置。示例文件使用占位符，防止密钥意外进入 Git 历史。
DEEPSEEK_API_KEY=your_deepseek_api_key
# 默认模型集中配置，便于在不改动业务代码的情况下切换模型。
DEFAULT_MODEL=deepseek-chat

# 向量嵌入模型。需确保运行环境已通过 Ollama 等服务部署对应模型。
EMBEDDING_MODEL=bge-m3

# ChromaDB 的相对数据目录，使本地开发环境具备可移植性。
CHROMA_PATH=resource/chroma_db